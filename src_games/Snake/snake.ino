Arduboy2 arduboy;

void setup() {
  arduboy.begin();
  #define 	SSD1306_COLUMNADDR   0x21
  #define 	SSD1306_PAGEADDR   0x22
  arduboy.sendLCDCommand(SSD1306_COLUMNADDR);
  arduboy.sendLCDCommand(16);   // Column start address (0 = reset)
  arduboy.sendLCDCommand(16+96-1); // Column end address (127 = reset)
  arduboy.sendLCDCommand(SSD1306_PAGEADDR);
  arduboy.sendLCDCommand(0); // Page start address (0 = reset)
  arduboy.sendLCDCommand(7); // Page end address

  resetcpu();
    
}


void loop() {
  run_cpu();
}


